{
  "name": "leadership-mcp",
  "version": "0.1.2",
  "description": "MCP server que distribui uma base de conhecimento viva sobre liderança humanista para o Claude. Inspirado em Barry-Wehmiller/Bob Chapman, Simon Sinek e na prática de Mario Campello.",
  "type": "module",
  "bin": {
    "leadership-mcp": "index.js"
  },
  "files": [
    "index.js",
    "knowledge-loader.js",
    "knowledge/"
  ],
  "scripts": {
    "start": "node index.js",
    "sync-knowledge": "rm -rf knowledge && cp -R ../knowledge knowledge",
    "smoke": "node smoke-test.js",
    "inspect": "npx @modelcontextprotocol/inspector node index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "leadership",
    "liderança",
    "liderança-humanista",
    "humanist-leadership",
    "claude"
  ],
  "author": "Mario Campello",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
